# Backend environment variables
# Copy this to .env and fill in your actual API keys

# Groq LLM API (for intent parsing, query expansion, explanations)
GROQ_API_KEY=your_groq_api_key_here

# TMDB API (for actor/director/genre lookups)
TMDB_API_KEY=your_tmdb_api_key_here

# Subtitle download API (for scraper script)
SUBDL_API_KEY=your_subdl_api_key_here
